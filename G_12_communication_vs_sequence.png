# Copy to example
cp results/workload/*.txt ../example/

For the simulation part for Ring only:
1. For sequence length: 128 
AS_SEND_LAT=2 AS_PXN_ENABLE=1 ./bin/SimAI_simulator -t 8 \
-w ./example/None-GPT-world_size8-tp4-pp1-ep1-gbs8-mbs1-seq128-numeric.txt \
-n ./Spectrum-X_8g_8gps_100Gbps_A100 \
-c astra-sim-alibabacloud/inputs/config/SimAI.conf \
2>&1 | tee results/ring_seq128.log

cp ncclFlowModel_EndToEnd.csv results/ring_seq128_EndToEnd.csv

2. For sequence length : 256
